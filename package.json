{
	"name": "obsidian-print-plugin",
	"version": "0.5.4",
	"description": "An Obsidian plugin for enhanced printing capabilities",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"test:watch": "vitest",
		"version": "node version-bump.mjs"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"print"
	],
	"author": "Marijn Bent",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^24.12.2",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.28.0",
		"jsdom": "^29.1.1",
		"obsidian": "^1.12.3",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"printd": "^1.6.0"
	}
}
